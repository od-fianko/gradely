# ── Database ──────────────────────────────────────────────────────────────────
# Local: postgresql://USER:PASSWORD@localhost:5432/gradely
# Production: Use Neon or Supabase connection string
DATABASE_URL="postgresql://user:password@localhost:5432/gradely"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Anthropic (AI grading — Short Answer module) ──────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Piston API (Code Execution) ───────────────────────────────────────────────
# Public instance (no key needed for basic use)
PISTON_API_URL="https://emkc.org/api/v2/piston"

# ── Vercel Blob (File Upload storage) ─────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Gradely"
